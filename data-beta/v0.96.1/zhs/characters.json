    "starting_hp": 80,
    "starting_gold": 99,
    "max_energy": 3,
    "orb_slots": null,
    "starting_deck": [
      "StrikeIronclad",
      "StrikeIronclad",
      "StrikeIronclad",
      "StrikeIronclad",
      "StrikeIronclad",
      "DefendIronclad",
      "DefendIronclad",
      "DefendIronclad",
      "DefendIronclad",
      "Bash"
    ],
    "starting_relics": [
      "BurningBlood"
    ],
    "unlocks_after": null,
    "gender": "Masculine",
    "color": "red",
    "dialogue_color": "new",
    "quotes": {
      "event_death_prevention": "我的队伍还需要我。",
      "gold_monologue": "[sine]这些财富可以充实部落的军库……[/sine]",
      "aroma_principle": "[sine][red]疼痛算得了什么，我的敌人们必须死。[/red][/sine]",
      "banter_alive": "快点。",
      "banter_dead": "……",
      "cards_modifier_title": "铁甲战士卡牌",
      "cards_modifier_description": "铁甲战士的卡牌现在会出现在奖励和商店中。"
    },
    "dialogues": [
      {
        "ancient": "NEOW",
        "ancient_name": "Neow",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[sine]…是时候…… 再次……\n……战斗了…… 战士啊……[/sine]"
          }
        ]
      },
      {
        "ancient": "NEOW",
        "ancient_name": "Neow",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[sine]……光荣的… 铁甲战士……\n…荣耀 等待着……[/sine]"
          }
        ]
      },
      {
        "ancient": "OROBAS",
        "ancient_name": "Orobas",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "*一名恶魔战士……欧洛巴斯很吃惊，真是有趣。*"
          }
        ]
      },
      {
        "ancient": "OROBAS",
        "ancient_name": "Orobas",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "*欧洛巴斯可以看看你的剑吗？多么有趣的武器。*"
          }
        ]
      },
      {
        "ancient": "PAEL",
        "ancient_name": "Pael",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[thinky_dots]你包含着如此的愤怒。从我这里取走一些，找到一些平静……[/thinky_dots]"
          }
        ]
      },
      {
        "ancient": "PAEL",
        "ancient_name": "Pael",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[thinky_dots]你还记得做梦的感觉吗？\n睡觉是件好事……[/thinky_dots]"
          }
        ]
      },
      {
        "ancient": "TANX",
        "ancient_name": "Tanx",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "多么残暴的怒火！是施行暴力的时间了！"
          }
        ]
      },
      {
        "ancient": "TANX",
        "ancient_name": "Tanx",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "收下我的力量！！摧毁你的敌人吧！"
          }
        ]
      },
      {
        "ancient": "TEZCATARA",
        "ancient_name": "Tezcatara",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "啊呀，你[jitter][b]燃烧[/b][/jitter]得真美！进来，进来！"
          }
        ]
      },
      {
        "ancient": "TEZCATARA",
        "ancient_name": "Tezcatara",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "你是个多么强壮的男孩啊！来，吃点东西吧。\n空着肚子可没法[jitter][b]杀戮[/b][/jitter]！"
          }
        ]
      },
      {
        "ancient": "VAKUU",
        "ancient_name": "Vakuu",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "失落的部落们是否仍让你感到沉重……？\n[i][font_size=22]瓦库狂笑。[/font_size][/i]"
          }
        ]
      }
    ],
    "image_url": "/static/images/characters/char_select_ironclad.webp"
  },
  {
    "id": "NECROBINDER",
    "name": "亡灵契约师",
    "description": "一位出生在尖塔的巫妖，正在寻求复仇。\n战斗中会召唤她可靠的左手[gold]奥斯提[/gold]。",
    "starting_hp": 66,
    "starting_gold": 99,
    "max_energy": 3,
    "orb_slots": null,
    "starting_deck": [
      "StrikeNecrobinder",
      "StrikeNecrobinder",
      "StrikeNecrobinder",
      "StrikeNecrobinder",
      "DefendNecrobinder",
      "DefendNecrobinder",
      "DefendNecrobinder",
      "DefendNecrobinder",
      "Bodyguard",
      "Unleash"
    ],
    "starting_relics": [
      "BoundPhylactery"
    ],
    "unlocks_after": "Regent",
    "gender": "Feminine",
    "color": "purple",
    "dialogue_color": "new",
    "quotes": {
      "event_death_prevention": "我的朋友们可不能没有我。",
      "gold_monologue": "[sine]或许我终于可以买几双鞋子了……[/sine]",
      "aroma_principle": "[sine][purple]他们的仇一定要报……我不会动摇……[/purple][/sine]",
      "banter_alive": "再等几天也行……",
      "banter_dead": "……",
      "unlock_text": "用[orange]？？？[/orange]进行一局游戏来解锁这个角色。",
      "cards_modifier_title": "亡灵契约师卡牌",
      "cards_modifier_description": "亡灵契约师的卡牌现在会出现在奖励和商店中。"
    },
    "dialogues": [
      {
        "ancient": "DARV",
        "ancient_name": "Darv",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "我是达弗，我收集财宝！你有财宝吗！？快给我！！"
          },
          {
            "order": 1,
            "speaker": "char",
            "text": "除了对复仇的渴望，我再无它物！让我过去！"
          },
          {
            "order": 2,
            "speaker": "ancient",
            "text": "好嘛好嘛！那你选个东西吧！\n要是找到有意思的东西再回来哈！！"
          }
        ]
      },
      {
        "ancient": "DARV",
        "ancient_name": "Darv",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "骷髅姑娘！！找到了点厉害的东西可以帮到你\n*达弗在包裹里翻找着*"
          }
        ]
      },
      {
        "ancient": "NEOW",
        "ancient_name": "Neow",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[sine]……一个… 孩子……？\n…接受…… 这份… 力量吧…！[/sine]"
          }
        ]
      },
      {
        "ancient": "OROBAS",
        "ancient_name": "Orobas",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "*一名巫妖……欧洛巴斯有些害怕。*"
          }
        ]
      },
      {
        "ancient": "OROBAS",
        "ancient_name": "Orobas",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "*不死的代价值得吗？和欧洛巴斯分享你的感受吧。*"
          }
        ]
      },
      {
        "ancient": "PAEL",
        "ancient_name": "Pael",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[thinky_dots]如此的恶意涂满你的心。[/thinky_dots]"
          }
        ]
      },
      {
        "ancient": "PAEL",
        "ancient_name": "Pael",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[thinky_dots]带着那只手回来了。\n痛苦的回忆。拿走我的力量然后离开……[/thinky_dots]"
          }
        ]
      },
      {
        "ancient": "PAEL",
        "ancient_name": "Pael",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[thinky_dots]杀死[red]父亲[/red]不会带来平静。[/thinky_dots]"
          },
          {
            "order": 1,
            "speaker": "char",
            "text": "你称那个[jitter]东西[/jitter]为你的父亲！？"
          },
          {
            "order": 2,
            "speaker": "ancient",
            "text": "[thinky_dots]我们无法选择自己的家人……[/thinky_dots]"
          }
        ]
      },
      {
        "ancient": "TANX",
        "ancient_name": "Tanx",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "一堆骨头？？那你显然需要我的力量！"
          }
        ]
      },
      {
        "ancient": "TANX",
        "ancient_name": "Tanx",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "没有肌腱，没有肉，没有蛋白质！你靠什么战斗？？"
          }
        ]
      },
      {
        "ancient": "TEZCATARA",
        "ancient_name": "Tezcatara",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "进来吧，进来！让你的火焰燃烧得更[jitter][b]明亮[/b][/jitter]。"
          }
        ]
      },
      {
        "ancient": "VAKUU",
        "ancient_name": "Vakuu",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "建筑师严重地伤害了我们俩。"
          }
        ]
      }
    ],
    "image_url": "/static/images/characters/char_select_necrobinder.webp"
  },
  {
    "id": "REGENT",
    "name": "储君",
    "description": "群星王座的继承人。\n拥有宇宙的力量，但总是让他的仆从们去做各种事情。",
    "starting_hp": 75,
    "starting_gold": 99,
    "max_energy": 3,
    "orb_slots": null,
    "starting_deck": [
      "StrikeRegent",
      "StrikeRegent",
      "StrikeRegent",
      "StrikeRegent",
      "DefendRegent",
      "DefendRegent",
      "DefendRegent",
      "DefendRegent",
      "FallingStar",
      "Venerate"
    ],
    "starting_relics": [
      "DivineRight"
    ],
    "unlocks_after": "Silent",
    "gender": "Masculine",
    "color": "orange",
    "dialogue_color": "new",
    "quotes": {
      "event_death_prevention": "为了我的队伍，我必须活下去！！",
      "gold_monologue": "[sine]我可以用这来征召一支不是白痴的军队……[/sine]",
      "aroma_principle": "[sine][orange]我是下一任群星之王……[/orange][/sine]",
      "banter_alive": "我等着！！",
      "banter_dead": "……",
      "unlock_text": "用[green]？？？[/green]进行一局游戏来解锁这个角色。",
      "cards_modifier_title": "储君卡牌",
      "cards_modifier_description": "储君的卡牌现在会出现在奖励和商店中。"
    },
    "dialogues": [
      {
        "ancient": "DARV",
        "ancient_name": "Darv",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "你这人长得奇形怪状的，身上有没有带着闪闪亮的东西啊？"
          },
          {
            "order": 1,
            "speaker": "char",
            "text": "我既不奇形怪状，也不是人……\n我乃是储君！！"
          }
        ]
      },
      {
        "ancient": "DARV",
        "ancient_name": "Darv",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "别挡道！我有财宝要找！！"
          },
          {
            "order": 1,
            "speaker": "char",
            "text": "不行！"
          },
          {
            "order": 2,
            "speaker": "ancient",
            "text": "*哐当*"
          }
        ]
      },
      {
        "ancient": "NEOW",
        "ancient_name": "Neow",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[sine]……我把你…… 带来[/sine]——"
          }
        ]
      },
      {
        "ancient": "OROBAS",
        "ancient_name": "Orobas",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "*群星之间的访客吗？和欧洛巴斯说说星星的事情吧。*"
          }
        ]
      },
      {
        "ancient": "OROBAS",
        "ancient_name": "Orobas",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "*和欧洛巴斯说说星达里斯的事情，欧洛巴斯需要知道更多。*"
          }
        ]
      },
      {
        "ancient": "PAEL",
        "ancient_name": "Pael",
        "lines": [
          {
            "order": 0,
            "speaker": "char",
            "text": "你好！我是储君。\n你好？？[jitter]你好！？[/jitter]"
          },
          {
            "order": 1,
            "speaker": "ancient",
            "text": "[thinky_dots]现在安静下来。\n拿走我的一部分，然后上路吧……[/thinky_dots]"
          }
        ]
      },
      {
        "ancient": "PAEL",
        "ancient_name": "Pael",
        "lines": [
          {
            "order": 0,
            "speaker": "char",
            "text": "我回来了！啊，你当然在睡觉。\n让我看看这里……"
          }
        ]
      },
      {
        "ancient": "PAEL",
        "ancient_name": "Pael",
        "lines": [
          {
            "order": 0,
            "speaker": "char",
            "text": "你为什么把自己送出去？"
          },
          {
            "order": 1,
            "speaker": "ancient",
            "text": "[thinky_dots]当我有大量的血肉时，为什么不给呢？[/thinky_dots]"
          },
          {
            "order": 2,
            "speaker": "ancient",
            "text": "[thinky_dots]当你回来时，我会重新补充。\n这就是睡眠的作用……[/thinky_dots]"
          }
        ]
      },
      {
        "ancient": "TANX",
        "ancient_name": "Tanx",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "你和伟大的坦克斯一样，也是橙色！？？"
          },
          {
            "order": 1,
            "speaker": "char",
            "text": "众所周知，橙色是最符合帝王的颜色！"
          },
          {
            "order": 2,
            "speaker": "ancient",
            "text": "橙色了不起！威风凛凛！！"
          }
        ]
      },
      {
        "ancient": "TEZCATARA",
        "ancient_name": "Tezcatara",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "啊呀呀，真是个[sine]稀奇[/sine]的访客！你是什么呀，亲爱的？"
          },
          {
            "order": 1,
            "speaker": "char",
