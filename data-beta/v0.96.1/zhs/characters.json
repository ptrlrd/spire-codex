    "starting_relics": [
      "CrackedCore"
    ],
    "unlocks_after": "Necrobinder",
    "gender": "Neutral",
    "color": "blue",
    "dialogue_color": "new",
    "quotes": {
      "event_death_prevention": "为了我的朋友们，我必须活下去！",
      "gold_monologue": "[sine]这些金币可以用来交换零件……[/sine]",
      "aroma_principle": "[sine][blue]1100 0011 1100 0011……[/blue][/sine]",
      "banter_alive": "^AHD2N@@iiW_P？",
      "banter_dead": "……",
      "unlock_text": "用[pink]？？？[/pink]进行一局游戏来解锁这个角色。",
      "cards_modifier_title": "故障机器人卡牌",
      "cards_modifier_description": "故障机器人的卡牌现在会出现在奖励和商店中。"
    },
    "dialogues": [
      {
        "ancient": "DARV",
        "ancient_name": "Darv",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "我和你说啊，你这块大型垃圾还真是挺好看的，你知道吧？"
          }
        ]
      },
      {
        "ancient": "NEOW",
        "ancient_name": "Neow",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[sine]……构造体…\n……活得… 很久…… 是吗……[/sine]"
          }
        ]
      },
      {
        "ancient": "NEOW",
        "ancient_name": "Neow",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[sine]……那个 ..[red]建筑师[/red]...\n....创造了.... 你们两个...[/sine]"
          }
        ]
      },
      {
        "ancient": "NONUPEIPE",
        "ancient_name": "Nonupeipe",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "你需要一些升级。\n时尚意味上的升级 >:)"
          }
        ]
      },
      {
        "ancient": "NONUPEIPE",
        "ancient_name": "Nonupeipe",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "所以——你能不能，留下来看守我的别墅呢？拜～托啦？"
          },
          {
            "order": 1,
            "speaker": "char",
            "text": "[i][font_size=22]*抱歉地摇头*[/font_size][/i]"
          }
        ]
      },
      {
        "ancient": "OROBAS",
        "ancient_name": "Orobas",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "*欧洛巴斯十分吃惊，竟有防水的构造体？*"
          }
        ]
      },
      {
        "ancient": "PAEL",
        "ancient_name": "Pael",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[thinky_dots]困扰的自动机，在找你的朋友吗？\n让我来帮忙……[/thinky_dots]"
          }
        ]
      },
      {
        "ancient": "PAEL",
        "ancient_name": "Pael",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "[thinky_dots]构造体会做梦吗？\n看着我，模仿我……[/thinky_dots]"
          }
        ]
      },
      {
        "ancient": "TEZCATARA",
        "ancient_name": "Tezcatara",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "故障了是吗？特兹卡塔拉当然可以帮助一个可怜的迷路构造体了。"
          }
        ]
      },
      {
        "ancient": "VAKUU",
        "ancient_name": "Vakuu",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "可悲的机器人啊，吾人颇为赏识你的陪伴。\n我们两个，皆是被 他 所抛弃了。"
          }
        ]
      },
      {
        "ancient": "VAKUU",
        "ancient_name": "Vakuu",
        "lines": [
          {
            "order": 0,
            "speaker": "ancient",
            "text": "如果你把建筑师的心脏带给我，我就恢复你的[aqua]同伴[/aqua]。"
          },
          {
            "order": 1,
            "speaker": "char",
            "text": "[i][font_size=22]*签下契约*[/font_size][/i]"
          }
        ]
      }
    ],
    "image_url": "/static/images/characters/char_select_defect.webp"
  },
  {
    "id": "IRONCLAD",
