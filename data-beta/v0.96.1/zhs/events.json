  {
    "id": "NEOW",
    "name": "涅奥",
    "type": "Ancient",
    "act": "Act 1 - Overgrowth / Underdocks",
    "description": "[sine]……再次…… ……问好………[/sine]",
    "preconditions": null,
    "options": null,
    "pages": null,
    "epithet": "复生之母（被放逐）",
    "dialogue": {
      "Returning": [
        {
          "order": "0-0r",
          "speaker": "ancient",
          "text": "[sine]……再次…… ……问好………[/sine]"
        },
        {
          "order": "1-0r",
          "speaker": "ancient",
          "text": "[sine]……醒来……\n…醒来………[/sine]"
        },
        {
          "order": "2-0r",
          "speaker": "ancient",
          "text": "[sine]…收下……这份……\n…祝福…… …去吧……[/sine]"
        }
      ],
      "Defect": [
        {
          "order": "0-0",
          "speaker": "ancient",
          "text": "[sine]……构造体…\n……活得… 很久…… 是吗……[/sine]"
        },
        {
          "order": "1-0r",
          "speaker": "ancient",
          "text": "[sine]……那个 ..[red]建筑师[/red]...\n....创造了.... 你们两个...[/sine]"
        }
      ],
      "Ironclad": [
        {
          "order": "0-0",
          "speaker": "ancient",
          "text": "[sine]…是时候…… 再次……\n……战斗了…… 战士啊……[/sine]"
        },
        {
          "order": "1-0r",
          "speaker": "ancient",
          "text": "[sine]……光荣的… 铁甲战士……\n…荣耀 等待着……[/sine]"
        }
      ],
      "Necrobinder": [
        {
          "order": "0-0",
          "speaker": "ancient",
          "text": "[sine]……一个… 孩子……？\n…接受…… 这份… 力量吧…！[/sine]"
        }
      ],
      "Regent": [
        {
          "order": "1-0r",
          "speaker": "ancient",
          "text": "[sine]……我把你…… 带来[/sine]——"
        }
      ],
      "Silent": [
        {
          "order": "0-0",
          "speaker": "ancient",
          "text": "[sine]……你又… 回来了…… 是吗？[/sine]"
        },
        {
          "order": "1-0r",
          "speaker": "ancient",
          "text": "[sine]……你的…\n ……战利品… 在等你……[/sine]"
        }
      ],
      "First Visit": [
        {
          "order": "0-0",
          "speaker": "ancient",
          "text": "[sine]……再次…… ……问好………[/sine]"
        }
      ]
    },
