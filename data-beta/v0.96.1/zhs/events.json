  {
    "id": "OROBAS",
    "name": "欧洛巴斯",
    "type": "Ancient",
    "act": "Act 2 - Hive",
    "description": "*一名恶魔战士……欧洛巴斯很吃惊，真是有趣。*",
    "preconditions": null,
    "options": null,
    "pages": null,
    "epithet": "活体虹光",
    "dialogue": {
      "Returning": [
        {
          "order": "0-0r",
          "speaker": "ancient",
          "text": "*又是你。欧洛巴斯因为这次意外的到访而喜悦。*"
        },
        {
          "order": "1-0r",
          "speaker": "ancient",
          "text": "*又是你。欧洛巴斯因为这次意外的到访而喜悦。*"
        }
      ],
      "Defect": [
        {
          "order": "0-0",
          "speaker": "ancient",
          "text": "*欧洛巴斯十分吃惊，竟有防水的构造体？*"
        }
      ],
      "Ironclad": [
        {
          "order": "0-0",
          "speaker": "ancient",
          "text": "*一名恶魔战士……欧洛巴斯很吃惊，真是有趣。*"
        },
        {
          "order": "1-0r",
          "speaker": "ancient",
          "text": "*欧洛巴斯可以看看你的剑吗？多么有趣的武器。*"
        }
      ],
      "Necrobinder": [
        {
          "order": "0-0",
          "speaker": "ancient",
          "text": "*一名巫妖……欧洛巴斯有些害怕。*"
        },
        {
          "order": "1-0r",
          "speaker": "ancient",
          "text": "*不死的代价值得吗？和欧洛巴斯分享你的感受吧。*"
        }
      ],
      "Regent": [
        {
          "order": "0-0",
          "speaker": "ancient",
          "text": "*群星之间的访客吗？和欧洛巴斯说说星星的事情吧。*"
        },
        {
          "order": "1-0r",
          "speaker": "ancient",
          "text": "*和欧洛巴斯说说星达里斯的事情，欧洛巴斯需要知道更多。*"
        }
      ],
      "Silent": [
        {
          "order": "1-0r",
          "speaker": "ancient",
          "text": "*不说话的人吶，给欧洛巴斯看看你杀死过的生物吧。*"
        }
      ]
    },
    "image_url": "/static/images/misc/ancients/orobas.webp",
